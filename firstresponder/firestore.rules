rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Volunteers readable by all auth users
    match /volunteers/{volunteerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == volunteerId;
      allow write: if isAdmin();
    }

    // Accidents readable by auth users
    match /accidents/{accidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Alerts readable by the volunteer it belongs to
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }

    // Hospitals readable by all auth users
    match /hospitals/{hospitalId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // First aid guides readable by all (even unauth for offline)
    match /firstAidGuides/{guideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ratings writable by authenticated users
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
