{
  "rules": {
    "volunteerLocations": {
      "$volunteerId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $volunteerId"
      }
    },
    "accidentRooms": {
      "$accidentId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
